{
  "name": "claude-code-testbed",
  "version": "0.5.2",
  "description": "Programmatic test harness for Claude Code plugins — spawns real Claude Code sessions under tmux",
  "type": "module",
  "exports": {
    ".": "./src/index.mjs",
    "./matchers": "./src/matchers.mjs",
    "./jsonl": "./src/jsonl.mjs",
    "./paths": "./src/paths.mjs",
    "./registry": "./src/registry.mjs",
    "./tmux": "./src/tmux.mjs"
  },
  "bin": {
    "claude-code-testbed": "src/cli.mjs",
    "claude-code-testbed-mcp": "mcp/testbed-mcp.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "src/**/*.mjs",
    ".claude-plugin/",
    "mcp/",
    "skills/",
    "commands/",
    "scripts/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roiperlman/claude-code-testbed.git"
  },
  "license": "MIT",
  "author": {
    "name": "Roi Perlman"
  },
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "testbed",
    "testing",
    "tmux",
    "e2e"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "semantic-release": "^24.2.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "peerDependencies": {
    "vitest": ">=1"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  }
}
