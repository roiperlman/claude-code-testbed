{
  "name": "claude-code-testbed",
  "version": "0.1.0",
  "description": "Programmatic test harness for Claude Code plugins — spawns real Claude Code sessions under tmux",
  "type": "module",
  "exports": {
    ".": "./src/index.mjs",
    "./jsonl": "./src/jsonl.mjs",
    "./paths": "./src/paths.mjs",
    "./registry": "./src/registry.mjs",
    "./tmux": "./src/tmux.mjs"
  },
  "bin": {
    "claude-code-testbed": "src/cli.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "src/**/*.mjs",
    ".claude-plugin/",
    "mcp/",
    "skills/",
    "commands/",
    "scripts/"
  ],
  "license": "MIT",
  "author": {
    "name": "Roi Perlman"
  },
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "testbed",
    "testing",
    "tmux",
    "e2e"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
